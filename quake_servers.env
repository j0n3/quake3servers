# Scalar settings for Quake3Servers.
#
# This file is plain KEY=value so it can be used both as a systemd
# EnvironmentFile and sourced from bash. Server definitions (which use bash
# arrays that systemd cannot parse) live in quake_servers.conf instead.

Q3SERVERS_HOSTNAME="lanparty.local"

# Tmux
Q3SERVERS_TMUX_SESSION="q3servers"

# Paths
Q3SERVERS_HOME="/usr/local/games/quake3servers"
Q3SERVERS_USER="lanparty"
Q3SERVERS_STEAM_QL_HOME="/home/lanparty/Steam/steamapps/common/Quake Live Dedicated Server"
Q3SERVERS_IOQ3_EXEC="/usr/lib/ioquake3/ioq3ded"
Q3SERVERS_Q3_EXEC="/usr/local/games/quake3/q3ded"
Q3SERVERS_LOG_DIR="/var/log/quake3servers"

# Redis
Q3SERVERS_REDIS_HOST="127.0.0.1"
Q3SERVERS_REDIS_PORT="6379"
Q3SERVERS_REDIS_DB="0"
Q3SERVERS_REDIS_PASSWORD=""

# Master server
Q3SERVERS_DPMASTER_PORT="27950"

# Passwords
Q3SERVERS_PASSWORD=""
Q3SERVERS_RCON_PASSWORD="changeme"

# FPS
Q3SERVERS_IOQ3_SV_FPS=120
Q3SERVERS_Q3_SV_FPS=120
Q3SERVERS_QL_SV_FPS=120

# Quake Live / minqlx
Q3SERVERS_QLX_OWNER=76561198004911379
Q3SERVERS_QLX_PLUGINS="plugin_manager, essentials, motd, permission, ban, silence, clan, names, log, workshop, balance, fun, uberstats"
