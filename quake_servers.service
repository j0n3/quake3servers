[Unit]
Description=Start Quake Servers in tmux session (QuakeServers)
After=network.target

[Service]
EnvironmentFile=/etc/quake_servers.env
Type=forking
User=lanparty
WorkingDirectory=/usr/local/games/quake3servers
ExecStart=/usr/local/games/quake3servers/start_quake_servers.sh
ExecStop=tmux kill-session -t ${Q3SERVERS_TMUX_SESSION}
Restart=on-failure
TTYPath=/dev/tty1
TTYVHangup=yes

[Install]
WantedBy=multi-user.target
